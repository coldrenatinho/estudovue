# Copie para .env para configurar o login real via Firebase Authentication.
# cp .env.example .env

# Configuração Web App do Firebase usada pelo frontend Vue.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Service account do Firebase Admin usado pelo backend para validar ID tokens.
# Opção 1: cole o JSON da service account em base64.
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Opção 2: use variáveis separadas. Para a private key, mantenha os caracteres \n.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Segredo usado para assinar JWT interno da API. Troque antes de publicar.
JWT_SECRET=troque-este-segredo-local

# Deixe true para o professor conseguir testar sem credenciais Firebase.
ENABLE_DEMO_LOGIN=true

# Banco de dados PostgreSQL usado pelo Docker Compose.
POSTGRES_USER=sebo
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=sebo_universitario
CORS_ORIGIN=http://localhost:8080,http://localhost:3000,http://localhost:5173

# Deploy remoto com Traefik.
# Exemplo:
# APP_DOMAIN=sebo.seudominio.com.br
# API_DOMAIN=api-sebo.seudominio.com.br
APP_DOMAIN=
API_DOMAIN=
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt
TRAEFIK_WEB_ROUTER=sebo-web
TRAEFIK_API_ROUTER=sebo-api
TRAEFIK_WEB_SERVICE=sebo-web
TRAEFIK_API_SERVICE=sebo-api
