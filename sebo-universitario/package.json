{
  "name": "sebo-universitario",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "bun ./node_modules/vite/bin/vite.js",
    "build": "bun run type-check && bun run build-only",
    "preview": "bun ./node_modules/vite/bin/vite.js preview",
    "build-only": "bun ./node_modules/vite/bin/vite.js build",
    "type-check": "bun ./node_modules/vue-tsc/bin/vue-tsc.js --build --force",
    "lint": "bun ./node_modules/eslint/bin/eslint.js",
    "lint:fix": "bun ./node_modules/eslint/bin/eslint.js --fix",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "api:dev": "cd api && bun install && bun run dev"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "@mdi/font": "7.4.47",
    "firebase": "^12.6.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "vuetify": "^4.0.2"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "npm-run-all2": "^8.0.4",
    "sass-embedded": "^1.98.0",
    "typescript": "~5.9.3",
    "unplugin-fonts": "^1.4.0",
    "vite": "^8.0.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-tsc": "^3.2.5",
    "eslint": "^9.39.4",
    "eslint-config-vuetify": "^4.3.4"
  },
  "overrides": {
    "unplugin-fonts": {
      "vite": "^8.0.0"
    }
  }
}
